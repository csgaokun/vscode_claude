# HOWTO COMPILE

 # go to your build folder of Qt Hldplugin
cd /path/to/qtc-build

# create and enter build directory for valgrind tests
mkdir valgrind-test
cd valgrind-test

# make library paths known to ldconfig
export LD_LIBRARY_PATH=/path/to/qtc-build/lib/qthldplugin:/path/to/qtc-build/lib/qthldplugin/plugins

# run qmake, make
qmake CONFIG+=debug IDE_BUILD_TREE=$(readlink -f ..) ../../path/to/qtc/tests/auto/valgrind
make
